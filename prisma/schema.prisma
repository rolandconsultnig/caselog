model AuditLog {
  id               String          @id @default(cuid())
  caseId           String?
  userId           String
  userName         String
  userRole         String
  action           AuditAction
  entityType       AuditEntityType
  entityId         String?
  entityName       String?
  changesMade      Json?
  affectedFields   String[]
  ipAddress        String?
  userAgent        String?
  location         String?
  deviceType       String?
  securityLevel    SecurityLevel   @default(LOW)
  suspicious       Boolean         @default(false)
  flaggedForReview Boolean         @default(false)
  reviewedBy       String?
  reviewedAt       DateTime?
  description      String?
  notes            String?
  timestamp        DateTime        @default(now())
  sessionId        String?
  case             Case?           @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user             User            @relation(fields: [userId], references: [id])

  @@index([caseId])
  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([timestamp])
  @@index([suspicious])
}

