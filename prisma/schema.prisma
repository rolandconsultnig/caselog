// Prisma schema for Comprehensive SGBV Case Management System - Phase 1
// This implements the core entities with 300+ fields

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// TENANT & USER MANAGEMENT
// ============================================

enum TenantType {
  STATE
  FEDERAL
}

enum AccessLevel {
  LEVEL_1 // Read only
  LEVEL_2 // Create cases
  LEVEL_3 // Approve/Reject cases
  LEVEL_4 // Delete with approval
  LEVEL_5 // Full approval authority
  SUPER_ADMIN // System administration
  APP_ADMIN // Application administrator
  PROSECUTOR
  INVESTIGATOR
}

model Tenant {
  id          String      @id @default(cuid())
  name        String      @unique
  code        String      @unique
  type        TenantType
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  users       User[]
  cases       Case[]
  
  @@index([type])
  @@index([code])
}

model User {
  id                String      @id @default(cuid())
  email             String      @unique
  password          String
  firstName         String
  lastName          String
  phoneNumber       String?
  accessLevel       AccessLevel
  tenantId          String
  tenant            Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  isActive          Boolean     @default(true)
  lastLogin         DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  
  casesCreated      Case[]      @relation("CaseCreator")
  casesInvestigating Case[]     @relation("CaseInvestigator")
  casesCoordinating Case[]      @relation("CaseCoordinator")
  auditLogs         AuditLog[]
  searchHistory     SearchHistory[] @relation("UserSearchHistory")
  savedSearches     SavedSearch[] @relation("UserSavedSearches")
  newsArticles      NewsArticle[] @relation("NewsAuthor")
  pageContent       PageContent[] @relation("PageContentEditor")
  
  @@index([tenantId])
  @@index([accessLevel])
  @@index([email])
}

// ============================================
// CASE MANAGEMENT (CORE ENTITY) - 40+ Fields
// ============================================

enum CaseType {
  SGBV
  TRAFFICKING
  DOMESTIC_VIOLENCE
  HARASSMENT
  OTHER
}

enum CaseStatus {
  NEW
  ACTIVE
  INVESTIGATION
  PENDING_COURT
  CLOSED
  ARCHIVED
}

enum CasePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
  CRITICAL
}

enum Jurisdiction {
  FEDERAL
  STATE
}

model Case {
  id                      String          @id @default(cuid())
  
  // Auto-Generated Fields
  caseNumber              String          @unique // CL-YYYYMM-XXXX
  reportedDate            DateTime        @default(now())
  
  // Required Fields (Minimum 4)
  title                   String          // max 255 chars
  description             String          @db.Text
  incidentDate            DateTime
  incidentState           String
  
  // Classification (With Defaults)
  caseType                CaseType        @default(SGBV)
  status                  CaseStatus      @default(NEW)
  priority                CasePriority    @default(MEDIUM)
  
  // Location Information - Incident
  incidentLga             String?
  incidentAddress         String?         @db.Text
  incidentLocation        Json?           // {lat, long}
  
  // Location Information - Reporting
  reportedState           String?
  reportedLga             String?
  reportedAddress         String?         @db.Text
  
  // Assignment
  investigatorId          String?
  investigator            User?           @relation("CaseInvestigator", fields: [investigatorId], references: [id])
  coordinatorId           String?
  coordinator             User?           @relation("CaseCoordinator", fields: [coordinatorId], references: [id])
  assignedState           String?
  jurisdiction            Jurisdiction    @default(FEDERAL)
  
  // Progress Tracking
  initialAssessmentCompleted Boolean      @default(false)
  investigationStarted    Boolean         @default(false)
  courtDate               DateTime?
  courtStatus             String?
  finalOutcome            String?         @db.Text
  convictionDate          DateTime?
  sentence                String?         @db.Text
  
  // Metadata Flags
  isSensitive             Boolean         @default(false)
  requiresSpecialHandling Boolean         @default(false)
  mediaInvolved           Boolean         @default(false)
  international           Boolean         @default(false)
  crossJurisdictional     Boolean         @default(false)
  
  // Tenant & Creator
  tenantId                String
  tenant                  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdById             String
  createdBy               User            @relation("CaseCreator", fields: [createdById], references: [id])
  
  // Timestamps
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  
  // Relationships
  victims                 Victim[]
  perpetrators            Perpetrator[]
  witnesses               Witness[]
  evidence                Evidence[]
  files                   CaseFile[]
  courtRecords            CourtRecord[]
  services                CaseService[]
  civilSocieties          CaseCivilSociety[]
  chatMessages            ChatMessage[]
  auditLogs               AuditLog[]
  
  @@index([tenantId])
  @@index([status])
  @@index([caseNumber])
  @@index([createdById])
  @@index([caseType])
  @@index([priority])
  @@index([incidentDate])
  @@index([investigatorId])
  @@index([coordinatorId])
}

// ============================================
// VICTIM MANAGEMENT - 70+ Fields Per Victim
// ============================================

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum RelationshipStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
  SEPARATED
  COHABITING
  INTIMATE_PARTNER
}

enum PreferredContactMethod {
  PHONE
  EMAIL
  SMS
  WHATSAPP
}

enum HIVStatus {
  POSITIVE
  NEGATIVE
  UNKNOWN
  DECLINED
}

enum PregnancyStatus {
  PREGNANT
  NOT_PREGNANT
  UNKNOWN
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Victim {
  id                      String          @id @default(cuid())
  caseId                  String
  case                    Case            @relation(fields: [caseId], references: [id], onDelete: Cascade)
  victimNumber            String          // V001, V002, etc.
  
  // Personal Information
  firstName               String
  middleName              String?
  lastName                String
  aliases                 String[]
  dateOfBirth             DateTime?
  age                     Int
  gender                  Gender
  nationality             String          @default("Nigerian")
  stateOfOrigin           String?
  lgaOfOrigin             String?
  
  // Contact Information
  phoneNumber             String?
  alternatePhone          String?
  email                   String?
  preferredContactMethod  PreferredContactMethod?
  
  // Current Address
  currentAddress          String?         @db.Text
  currentCity             String?
  currentState            String?
  currentLga              String?
  currentPostalCode       String?
  
  // Permanent Address
  permanentAddress        String?         @db.Text
  permanentCity           String?
  permanentState          String?
  permanentLga            String?
  sameAsCurrent           Boolean         @default(false)
  
  // Emergency Contact 1
  emergencyContact1Name   String?
  emergencyContact1Relationship String?
  emergencyContact1Phone  String?
  emergencyContact1Address String?       @db.Text
  
  // Emergency Contact 2
  emergencyContact2Name   String?
  emergencyContact2Relationship String?
  emergencyContact2Phone  String?
  emergencyContact2Address String?       @db.Text
  
  // Medical & Health
  medicalHistory          String?         @db.Text
  currentMedications      String?         @db.Text
  allergies               String?         @db.Text
  disabilities            String?         @db.Text
  mentalHealthConditions  String?         @db.Text
  substanceAbuse          String?         @db.Text
  hivStatus               HIVStatus?
  pregnancyStatus         PregnancyStatus?
  
  // Incident-Specific Information
  relationshipToPerpetrator String?
  incidentDescription     String?         @db.Text
  injuriesSustained       String?         @db.Text
  medicalTreatmentReceived Boolean?
  hospitalName            String?
  medicalReportNumber     String?
  psychologicalImpact     String?         @db.Text
  
  // Support Services
  servicesNeeded          String[]
  servicesProvided        String[]
  shelterRequired         Boolean         @default(false)
  shelterProvided         Boolean         @default(false)
  legalAidRequired        Boolean         @default(false)
  counselingRequired      Boolean         @default(false)
  
  // Privacy & Consent
  consentToShare          Boolean         @default(false)
  consentToPhotograph     Boolean         @default(false)
  consentToTestify        Boolean         @default(false)
  anonymityRequested      Boolean         @default(false)
  protectionOrderRequired Boolean         @default(false)
  
  // Victim Statement
  statementText           String?         @db.Text
  statementDate           DateTime?
  statementRecordedBy     String?
  statementAudioPath      String?
  statementVideoPath      String?
  statementVerified       Boolean         @default(false)
  
  // Risk Assessment
  riskLevel               RiskLevel       @default(MEDIUM)
  riskFactors             String[]
  safetyPlan              String?         @db.Text
  immediateThreats        String?         @db.Text
  
  // Metadata
  isMinor                 Boolean         @default(false)
  isDeceased              Boolean         @default(false)
  isDisabled              Boolean         @default(false)
  requiresInterpreter     Boolean         @default(false)
  interpreterLanguage     String?
  
  // Biometric Data
  photographPath          String?
  photographUploadDate    DateTime?
  facialRecognitionData   Json?           // Facial recognition embeddings
  facialRecognitionId     String?         // Unique facial ID
  fingerprintData         Json?           // Fingerprint data
  fingerprintId           String?         // Unique fingerprint ID
  biometricVerified       Boolean         @default(false)
  
  // Timestamps
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  
  @@index([caseId])
  @@index([victimNumber])
  @@index([isMinor])
  @@index([facialRecognitionId])
  @@index([fingerprintId])
}

// ============================================
// PERPETRATOR MANAGEMENT - 60+ Fields
// ============================================

enum BuildType {
  SLIM
  AVERAGE
  HEAVY
  MUSCULAR
}

enum ConditionStatus {
  EXCELLENT
  GOOD
  FAIR
  POOR
}

enum CooperationLevel {
  COOPERATIVE
  UNCOOPERATIVE
  HOSTILE
}

model Perpetrator {
  id                      String          @id @default(cuid())
  caseId                  String
  case                    Case            @relation(fields: [caseId], references: [id], onDelete: Cascade)
  perpetratorNumber       String          // P001, P002, etc.
  
  // Personal Information
  firstName               String
  middleName              String?
  lastName                String
  aliases                 String[]
  dateOfBirth             DateTime?
  age                     Int?
  gender                  Gender?
  nationality             String?
  stateOfOrigin           String?
  
  // Physical Description
  height                  String?
  weight                  String?
  buildType               BuildType?
  complexion              String?
  eyeColor                String?
  hairColor               String?
  hairStyle               String?
  facialHair              String?
  distinctiveFeatures     String?         @db.Text
  tattoos                 String?         @db.Text
  scars                   String?         @db.Text
  piercings               String?         @db.Text
  
  // Contact Information
  phoneNumber             String?
  alternatePhone          String?
  email                   String?
  socialMediaAccounts     Json?
  
  // Known Associates
  knownAssociates         String?         @db.Text
  gangAffiliation         String?
  accomplices             String[]
  
  // Current Address
  currentAddress          String?         @db.Text
  currentCity             String?
  currentState            String?
  currentLga              String?
  
  // Previous Addresses
  previousAddresses       Json[]
  
  // Workplace
  workplaceName           String?
  workplaceAddress        String?         @db.Text
  occupation              String?
  
  // Relationship to Victim
  relationshipToVictim    String?
  relationshipDuration    String?
  cohabitation            Boolean         @default(false)
  dependents              Int?
  
  // Legal Status & Arrest Details (Enhanced)
  arrested                Boolean         @default(false)
  arrestDate              DateTime?
  arrestTime              String?
  arrestLocation          String?
  arrestLocationAddress   String?         @db.Text
  arrestingAgency         String?
  arrestingOfficer        String?
  arrestingOfficerName    String?
  arrestingOfficerRank    String?
  arrestingOfficerBadge   String?
  arrestingOfficerStation String?
  arrestingOfficerPhone   String?
  arrestWarrantNumber     String?
  arrestWarrantDate       DateTime?
  arrestReason            String?         @db.Text
  arrestCircumstances     String?         @db.Text
  resistedArrest          Boolean         @default(false)
  arrestWitnesses         String[]
  
  // Custody Details
  detentionFacility       String?
  detentionFacilityAddress String?       @db.Text
  custodyStartDate        DateTime?
  custodyStartTime        String?
  custodyEndDate          DateTime?
  custodyEndTime          String?
  custodyDuration         Int?
  cellNumber              String?
  custodyOfficerName      String?
  custodyOfficerBadge     String?
  
  // Case Reporting
  caseReportedBy          String?
  reporterRelationship    String?
  reporterContact         String?
  reportDate              DateTime?
  reportTime              String?
  reportLocation          String?
  firstRespondingOfficer  String?
  
  // Release Details
  released                Boolean         @default(false)
  releaseDate             DateTime?
  releaseTime             String?
  releaseType             String?
  releaseAuthority        String?
  releaseAuthorityRank    String?
  releaseDocumentNumber   String?
  
  // Charges
  chargesField            Boolean         @default(false)
  chargeDetails           String?         @db.Text
  chargeDate              DateTime?
  
  // Bail Information (Enhanced)
  onBail                  Boolean         @default(false)
  bailGranted             Boolean         @default(false)
  bailAmount              Decimal?        @db.Decimal(10, 2)
  bailDate                DateTime?
  bailConditions          String?         @db.Text
  bailBondNumber          String?
  bailGrantedBy           String?
  bailGrantedDate         DateTime?
  
  // Surety Information (Enhanced)
  suretyRequired          Boolean         @default(false)
  suretyName              String?
  suretyFullName          String?
  suretyDateOfBirth       DateTime?
  suretyGender            String?
  suretyNIN               String?
  suretyPhone             String?
  suretyPhoneNumber       String?
  suretyEmail             String?
  suretyOccupation        String?
  suretyEmployer          String?
  suretyAddress           String?         @db.Text
  suretyCity              String?
  suretyState             String?
  suretyLGA               String?
  suretyRelationshipToAccused String?
  suretyIDType            String?
  suretyIDNumber          String?
  suretyPhotoPath         String?
  suretySignaturePath     String?
  
  // Address Verification
  addressVerified         Boolean         @default(false)
  addressVerifiedBy       String?
  addressVerifierRank     String?
  addressVerifierBadge    String?
  addressVerificationDate DateTime?
  addressVerificationReport String?       @db.Text
  landlordName            String?
  landlordContact         String?
  verificationPhotosPath  String[]
  
  // Investigation Information
  suspectStatement        String?         @db.Text
  statementDate           DateTime?
  lawyerName              String?
  lawyerContact           String?
  cooperationLevel        CooperationLevel?
  
  // Risk Assessment
  flightRisk              RiskLevel       @default(MEDIUM)
  violenceRisk            RiskLevel       @default(MEDIUM)
  riskToPublic            Boolean         @default(false)
  riskFactors             String[]
  
  // Criminal History
  priorConvictions        Boolean         @default(false)
  priorConvictionsDetails String?         @db.Text
  priorArrests            Int             @default(0)
  priorSGBVCases          Boolean         @default(false)
  restrainingOrders       Boolean         @default(false)
  
  // Biometric Data
  photographPath          String?
  photographUploadDate    DateTime?
  facialRecognitionData   Json?           // Facial recognition embeddings
  facialRecognitionId     String?         // Unique facial ID
  fingerprintData         Json?           // Fingerprint data
  fingerprintId           String?         // Unique fingerprint ID
  biometricVerified       Boolean         @default(false)
  biometricVerifiedDate   DateTime?
  biometricVerifiedBy     String?
  
  // Timestamps
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  
  @@index([caseId])
  @@index([perpetratorNumber])
  @@index([arrested])
  @@index([facialRecognitionId])
  @@index([fingerprintId])
}

// ============================================
// EVIDENCE MANAGEMENT - 60+ Fields
// ============================================

enum EvidenceType {
  PHYSICAL
  DIGITAL
  DOCUMENTARY
  FORENSIC
  TESTIMONIAL
  PHOTOGRAPHIC
  VIDEO
  AUDIO
  OTHER
}

enum StorageType {
  EVIDENCE_ROOM
  LAB
  DIGITAL_STORAGE
  COURT
  OTHER
}

enum CustodyStatus {
  IN_CUSTODY
  TRANSFERRED
  RELEASED
  DESTROYED
}

enum VirusScanResult {
  CLEAN
  INFECTED
  SUSPICIOUS
  NOT_SCANNED
}

model Evidence {
  id                      String          @id @default(cuid())
  caseId                  String
  case                    Case            @relation(fields: [caseId], references: [id], onDelete: Cascade)
  evidenceNumber          String          // E001, E002, etc.
  
  // Basic Information
  evidenceType            EvidenceType
  description             String          @db.Text
  category                String?
  subcategory             String?
  
  // Collection Details
  collectedDate           DateTime
  collectedTime           String?
  collectedBy             String
  collectedByName         String
  collectionLocation      String          @db.Text
  collectionMethod        String?         @db.Text
  collectionCircumstances String?         @db.Text
  
  // Physical Evidence Details
  physicalDescription     String?         @db.Text
  dimensions              String?
  weight                  String?
  color                   String?
  material                String?
  condition               ConditionStatus @default(GOOD)
  quantity                Int             @default(1)
  
  // Digital Evidence Details
  deviceType              String?
  deviceMake              String?
  deviceModel             String?
  deviceSerialNumber      String?
  storageCapacity         String?
  dataType                String?
  fileFormat              String?
  fileSize                String?
  hashValue               String?
  
  // Storage Information
  storageLocation         String
  storageType             StorageType
  storageConditions       String?
  containerType           String?
  sealNumber              String?
  
  // Forensic Analysis
  forensicAnalysisRequired Boolean        @default(false)
  forensicAnalysisRequested Boolean       @default(false)
  forensicAnalysisDate    DateTime?
  forensicLab             String?
  forensicAnalystName     String?
  forensicAnalystID       String?
  forensicReportNumber    String?
  forensicReportPath      String?
  forensicFindings        String?         @db.Text
  dnaProfile              String?
  fingerprintsFound       Boolean         @default(false)
  
  // Legal Admissibility
  admissible              Boolean         @default(true)
  admissibilityNotes      String?         @db.Text
  legalChallenges         String?         @db.Text
  expertWitnessRequired   Boolean         @default(false)
  expertWitnessName       String?
  
  // Chain of Custody
  currentCustodian        String
  currentCustodianName    String
  custodyStatus           CustodyStatus   @default(IN_CUSTODY)
  
  // Quality Control
  photographed            Boolean         @default(false)
  photographPath          String?
  videographed            Boolean         @default(false)
  videoPath               String?
  documented              Boolean         @default(true)
  documentationComplete   Boolean         @default(false)
  qualityCheckPassed      Boolean         @default(false)
  qualityCheckBy          String?
  qualityCheckDate        DateTime?
  
  // Metadata
  tags                    String[]
  notes                   String?         @db.Text
  relatedEvidenceIds      String[]
  isKeyEvidence           Boolean         @default(false)
  presentedInCourt        Boolean         @default(false)
  courtPresentationDate   DateTime?
  
  // Timestamps
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  
  // Relationships
  chainOfCustody          ChainOfCustody?
  
  @@index([caseId])
  @@index([evidenceNumber])
  @@index([evidenceType])
  @@index([custodyStatus])
}

// ============================================
// AUDIT LOG - Complete Activity Tracking
// ============================================

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  APPROVE
  REJECT
  ASSIGN
  TRANSFER
  EXPORT
  PRINT
  SHARE
  LOGIN
  LOGOUT
}

enum AuditEntityType {
  CASE
  VICTIM
  PERPETRATOR
  WITNESS
  EVIDENCE
  DOCUMENT
  USER
  SYSTEM
}

enum SecurityLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model AuditLog {
  id                      String          @id @default(cuid())
  
  // Case Reference (optional)
  caseId                  String?
  case                    Case?           @relation(fields: [caseId], references: [id], onDelete: Cascade)
  
  // User Information
  userId                  String
  user                    User            @relation(fields: [userId], references: [id])
  userName                String
  userRole                String
  
  // Action Details
  action                  AuditAction
  entityType              AuditEntityType
  entityId                String?
  entityName              String?
  
  // Change Tracking
  changesMade             Json?           // {field, oldValue, newValue}
  affectedFields          String[]
  
  // Context
  ipAddress               String?
  userAgent               String?
  location                String?
  deviceType              String?
  
  // Security
  securityLevel           SecurityLevel   @default(LOW)
  suspicious              Boolean         @default(false)
  flaggedForReview        Boolean         @default(false)
  reviewedBy              String?
  reviewedAt              DateTime?
  
  // Metadata
  description             String?         @db.Text
  notes                   String?         @db.Text
  timestamp               DateTime        @default(now())
  sessionId               String?
  
  @@index([caseId])
  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([timestamp])
  @@index([suspicious])
}

// ============================================
// WITNESS MANAGEMENT - 50+ Fields Per Witness (PHASE 2)
// ============================================

enum WitnessType {
  EYEWITNESS
  CHARACTER
  EXPERT
  HEARSAY
}

enum CredibilityRating {
  LOW
  MEDIUM
  HIGH
}

enum ProtectionLevel {
  NONE
  LOW
  MEDIUM
  HIGH
}

enum ThreatLevel {
  NONE
  LOW
  MEDIUM
  HIGH
}

model Witness {
  id                      String          @id @default(cuid())
  caseId                  String
  case                    Case            @relation(fields: [caseId], references: [id], onDelete: Cascade)
  witnessNumber           String          // W001, W002, etc.
  
  // Personal Information
  firstName               String
  middleName              String?
  lastName                String
  dateOfBirth             DateTime?
  age                     Int?
  gender                  Gender?
  nationality             String?
  occupation              String?
  
  // Contact Information
  phoneNumber             String?
  alternatePhone          String?
  email                   String?
  address                 String?         @db.Text
  city                    String?
  state                   String?
  
  // Relationship to Case
  relationshipToVictim    String?
  relationshipToPerpetrator String?
  witnessType             WitnessType
  
  // Witness Statement
  statementText           String          @db.Text
  statementDate           DateTime
  statementRecordedBy     String?
  statementLocation       String?
  statementAudioPath      String?
  statementVideoPath      String?
  statementDocumentPath   String?
  statementVerified       Boolean         @default(false)
  statementSigned         Boolean         @default(false)
  
  // Credibility Assessment
  credibilityRating       CredibilityRating @default(MEDIUM)
  credibilityNotes        String?         @db.Text
  inconsistencies         String?         @db.Text
  corroboratingEvidence   String?         @db.Text
  
  // Testimony Information
  availableForTestimony   Boolean         @default(true)
  courtAppearanceDate     DateTime?
  courtAppearanceConfirmed Boolean        @default(false)
  testimonyChallenges     String?         @db.Text
  needsAccommodation      Boolean         @default(false)
  accommodationDetails    String?         @db.Text
  
  // Protection Measures
  protectionRequired      Boolean         @default(false)
  protectionLevel         ProtectionLevel @default(NONE)
  protectionMeasures      String[]
  threatLevel             ThreatLevel     @default(NONE)
  threatsReceived         String?         @db.Text
  
  // Risk Assessment
  riskLevel               RiskLevel       @default(LOW)
  riskFactors             String[]
  intimidationAttempts    Boolean         @default(false)
  intimidationDetails     String?         @db.Text
  
  // Metadata
  isMinor                 Boolean         @default(false)
  requiresInterpreter     Boolean         @default(false)
  interpreterLanguage     String?
  specialNeeds            String?         @db.Text
  
  // Timestamps
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  
  @@index([caseId])
  @@index([witnessNumber])
  @@index([witnessType])
}

// ============================================
// CHAIN OF CUSTODY - 40+ Fields (PHASE 2)
// ============================================

model ChainOfCustody {
  id                      String          @id @default(cuid())
  evidenceId              String          @unique
  evidence                Evidence        @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  transferNumber          String          // COC001, COC002, etc.
  
  // Current Custodian Information
  currentCustodian        String
  currentCustodianName    String
  currentCustodianTitle   String?
  currentCustodianAgency  String?
  currentCustodianBadgeNumber String?
  
  // Transfer History (JSON array)
  transferHistory         Json[]          // Array of transfer records
  
  // Documentation
  documentationComplete   Boolean         @default(false)
  allSignaturesObtained   Boolean         @default(false)
  photographicRecord      Boolean         @default(false)
  videoRecord             Boolean         @default(false)
  
  // Legal Compliance
  compliesWithStandards   Boolean         @default(true)
  complianceNotes         String?         @db.Text
  breaches                Json[]          // Array of breach records
  correctiveActions       String?         @db.Text
  
  // Integrity Maintenance
  sealIntact              Boolean         @default(true)
  tamperEvident           Boolean         @default(false)
  conditionChanges        String?         @db.Text
  environmentalConditions String?         @db.Text
  
  // Metadata
  lastVerifiedDate        DateTime?
  lastVerifiedBy          String?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  
  // Relationships
  custodyTransfers        CustodyTransfer[]
  
  @@index([evidenceId])
  @@index([transferNumber])
}

// ============================================
// CUSTODY TRANSFERS - 35+ Fields (PHASE 2)
// ============================================

enum TransferReason {
  ANALYSIS
  STORAGE
  COURT_PRESENTATION
  RETURN
  DISPOSAL
  OTHER
}

enum TransferCondition {
  EXCELLENT
  GOOD
  FAIR
  POOR
}

model CustodyTransfer {
  id                      String          @id @default(cuid())
  chainOfCustodyId        String
  chainOfCustody          ChainOfCustody  @relation(fields: [chainOfCustodyId], references: [id], onDelete: Cascade)
  transferNumber          String          // T001, T002, etc.
  
  // Transfer From
  transferredFrom         String
  transferredFromName     String
  transferredFromTitle    String?
  transferredFromAgency   String?
  
  // Transfer To
  transferredTo           String
  transferredToName       String
  transferredToTitle      String?
  transferredToAgency     String?
  
  // Transfer Details
  transferDate            DateTime
  transferTime            String
  transferLocation        String
  
  // Transfer Reason
  transferReason          TransferReason
  reasonDetails           String?         @db.Text
  
  // Transfer Documentation
  transferFormNumber      String?
  transferFormPath        String?
  transferAuthorization   String?
  authorizedBy            String?
  authorizationDate       DateTime?
  
  // Condition Assessment
  conditionBefore         TransferCondition @default(GOOD)
  conditionAfter          TransferCondition @default(GOOD)
  conditionNotes          String?         @db.Text
  damageReported          Boolean         @default(false)
  damageDescription       String?         @db.Text
  
  // Verification
  receivedBy              String
  receivedByName          String
  receivedDate            DateTime
  receivedTime            String
  verificationMethod      String?
  discrepanciesNoted      Boolean         @default(false)
  discrepancyDetails      String?         @db.Text
  
  // Signatures
  transferrerSignature    String
  transferrerSignatureDate DateTime
  receiverSignature       String
  receiverSignatureDate   DateTime
  witnessSignature        String?
  witnessName             String?
  
  // Legal Compliance
  compliesWithProtocol    Boolean         @default(true)
  protocolDeviations      String?         @db.Text
  correctiveActions       String?         @db.Text
  
  // Metadata
  notes                   String?         @db.Text
  attachments             String[]
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  
  @@index([chainOfCustodyId])
  @@index([transferNumber])
  @@index([transferDate])
}

// ============================================
// FILES/DOCUMENTS - 25+ Fields (PHASE 2)
// ============================================

enum FileType {
  MEDICAL_REPORT
  FORENSIC_REPORT
  PHOTO
  VIDEO
  AUDIO
  LEGAL_DOCUMENT
  STATEMENT
  OTHER
}

enum StorageProvider {
  LOCAL
  S3
  AZURE
  GOOGLE_CLOUD
}

enum FileAccessLevel {
  PUBLIC
  INTERNAL
  RESTRICTED
  CONFIDENTIAL
}

model CaseFile {
  id                      String          @id @default(cuid())
  caseId                  String
  case                    Case            @relation(fields: [caseId], references: [id], onDelete: Cascade)
  
  // Related Entity (optional)
  relatedEntityType       String?         // case, victim, perpetrator, witness, evidence
  relatedEntityId         String?
  
  // Basic Information
  fileName                String
  originalFileName        String
  fileType                FileType
  mimeType                String
  fileSize                Int
  
  // Storage Information
  filePath                String
  storageProvider         StorageProvider @default(LOCAL)
  bucketName              String?
  fileUrl                 String?
  thumbnailUrl            String?
  
  // Security
  encrypted               Boolean         @default(true)
  encryptionMethod        String?
  accessLevel             FileAccessLevel @default(INTERNAL)
  passwordProtected       Boolean         @default(false)
  
  // Virus Scanning
  virusScanned            Boolean         @default(false)
  virusScanDate           DateTime?
  virusScanResult         VirusScanResult @default(NOT_SCANNED)
  virusScanEngine         String?
  
  // Metadata
  uploadedBy              String
  uploadedByName          String
  uploadDate              DateTime        @default(now())
  description             String?         @db.Text
  tags                    String[]
  category                String?
  
  // Document-Specific
  pageCount               Int?
  documentDate            DateTime?
  documentAuthor          String?
  documentNumber          String?
  
  // Media-Specific
  duration                Int?            // seconds
  resolution              String?
  codec                   String?
  
  // Version Control
  version                 Int             @default(1)
  previousVersionId       String?
  isLatestVersion         Boolean         @default(true)
  
  // Usage Tracking
  downloadCount           Int             @default(0)
  lastAccessedDate        DateTime?
  lastAccessedBy          String?
  
  // Timestamps
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  
  @@index([caseId])
  @@index([fileType])
  @@index([relatedEntityType, relatedEntityId])
}

// ============================================
// CASE OFFENCES - Legal Charges (PHASE 2)
// ============================================

enum PleaType {
  GUILTY
  NOT_GUILTY
  NO_CONTEST
  NOT_ENTERED
}

enum VerdictType {
  GUILTY
  NOT_GUILTY
  DISMISSED
  ACQUITTED
}

enum SentenceType {
  CUSTODIAL
  NON_CUSTODIAL
  FINE
  PROBATION
  COMMUNITY_SERVICE
  SUSPENDED
}

model CourtRecord {
  id                      String          @id @default(cuid())
  caseId                  String
  case                    Case            @relation(fields: [caseId], references: [id], onDelete: Cascade)
  offenceNumber           String          // OFF001, OFF002, etc.
  
  // Basic Information
  offenceName             String
  offenceCode             String?
  offenceCategory         String?
  
  // Legal Details
  law                     String          // e.g., "Section 283 Penal Code"
  section                 String?
  act                     String?         // e.g., "VAPPA", "CRA"
  penalty                 String          @db.Text
  minimumSentence         String?
  maximumSentence         String?
  
  // Charge Details
  chargeDate              DateTime?
  chargeNumber            String?
  chargingAuthority       String?
  chargedBy               String?
  
  // Evidence
  evidenceIds             String[]
  witnessIds              String[]
  supportingDocuments     String[]
  
  // Plea Status
  pleaEntered             Boolean         @default(false)
  pleaDate                DateTime?
  pleaType                PleaType        @default(NOT_ENTERED)
  pleaBargain             Boolean         @default(false)
  pleaBargainDetails      String?         @db.Text
  
  // Trial Information
  trialDate               DateTime?
  trialLocation           String?
  courtName               String?
  prosecutorId            String?
  defenseAttorney         String?
  presidingJudge          String?
  
  // Verdict
  verdictReached          Boolean         @default(false)
  verdictDate             DateTime?
  verdict                 VerdictType?
  verdictDetails          String?         @db.Text
  
  // Sentence
  sentenced               Boolean         @default(false)
  sentenceDate            DateTime?
  sentenceType            SentenceType?
  sentenceDuration        String?
  fineAmount              Decimal?        @db.Decimal(15, 2)
  sentenceDetails         String?         @db.Text
  
  // Appeal Status
  appealFiled             Boolean         @default(false)
  appealDate              DateTime?
  appealOutcome           String?
  appealDetails           String?         @db.Text
  
  // Metadata
  notes                   String?         @db.Text
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  
  @@index([caseId])
  @@index([offenceNumber])
  @@index([offenceCode])
}

// ============================================
// CASE SERVICES - Service Referrals (PHASE 3)
// ============================================

enum ServiceType {
  MEDICAL
  PSYCHOLOGICAL
  LEGAL
  SHELTER
  FINANCIAL
  VOCATIONAL
  EDUCATIONAL
  OTHER
}

enum ProviderType {
  GOVERNMENT
  NGO
  PRIVATE
  INDIVIDUAL
}

enum ServiceUrgency {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ServiceStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
  DECLINED
}

enum PaymentStatus {
  NOT_APPLICABLE
  PENDING
  PAID
  PARTIALLY_PAID
  WAIVED
}

enum SatisfactionLevel {
  VERY_DISSATISFIED
  DISSATISFIED
  NEUTRAL
  SATISFIED
  VERY_SATISFIED
}

model CaseService {
  id                      String          @id @default(cuid())
  caseId                  String
  case                    Case            @relation(fields: [caseId], references: [id], onDelete: Cascade)
  victimId                String?
  serviceNumber           String          // SRV001, SRV002, etc.
  
  // Basic Information
  serviceType             ServiceType
  serviceCategory         String?
  serviceName             String
  
  // Provider Information
  providerName            String
  providerType            ProviderType
  providerContact         String?
  providerAddress         String?         @db.Text
  providerEmail           String?
  providerPhone           String?
  
  // Referral Details
  referralDate            DateTime
  referredBy              String
  referredByName          String
  referralReason          String          @db.Text
  urgency                 ServiceUrgency  @default(MEDIUM)
  
  // Appointment Details
  appointmentScheduled    Boolean         @default(false)
  appointmentDate         DateTime?
  appointmentTime         String?
  appointmentLocation     String?
  appointmentConfirmed    Boolean         @default(false)
  appointmentAttended     Boolean         @default(false)
  appointmentOutcome      String?         @db.Text
  
  // Service Delivery
  serviceStartDate        DateTime?
  serviceEndDate          DateTime?
  serviceDuration         Int?            // days
  sessionsPlanned         Int?
  sessionsCompleted       Int             @default(0)
  serviceStatus           ServiceStatus   @default(PENDING)
  
  // Cost Tracking
  estimatedCost           Decimal?        @db.Decimal(15, 2)
  actualCost              Decimal?        @db.Decimal(15, 2)
  fundingSource           String?
  paymentStatus           PaymentStatus   @default(NOT_APPLICABLE)
  
  // Outcome & Feedback
  outcomeAchieved         Boolean?
  outcomeDescription      String?         @db.Text
  beneficiarySatisfaction SatisfactionLevel?
  feedback                String?         @db.Text
  followUpRequired        Boolean         @default(false)
  followUpDate            DateTime?
  
  // Metadata
  notes                   String?         @db.Text
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  
  @@index([caseId])
  @@index([serviceNumber])
  @@index([serviceType])
  @@index([serviceStatus])
}

// ============================================
// CASE CIVIL SOCIETIES - NGO Partnerships (PHASE 3)
// ============================================

enum SupportFrequency {
  ONE_TIME
  WEEKLY
  BI_WEEKLY
  MONTHLY
  QUARTERLY
  ONGOING
}

enum NGOSatisfactionRating {
  POOR
  FAIR
  GOOD
  EXCELLENT
}

model CaseCivilSociety {
  id                      String          @id @default(cuid())
  caseId                  String
  case                    Case            @relation(fields: [caseId], references: [id], onDelete: Cascade)
  partnershipNumber       String          // NGO001, NGO002, etc.
  
  // Basic Information
  ngoName                 String
  ngoType                 String?
  ngoRegistrationNumber   String?
  
  // Contact Information
  contactPerson           String
  contactTitle            String?
  contactEmail            String?
  contactPhone            String
  officeAddress           String?         @db.Text
  
  // Referral Details
  referralDate            DateTime
  referredBy              String
  referralReason          String          @db.Text
  servicesRequested       String[]
  
  // Support Duration
  supportStartDate        DateTime
  supportEndDate          DateTime?
  supportDuration         Int?            // months
  supportFrequency        SupportFrequency?
  
  // Progress Tracking
  progressReports         Json[]          // Array of progress report objects
  milestonesAchieved      String[]
  challengesFaced         String?         @db.Text
  
  // Final Report
  finalReportSubmitted    Boolean         @default(false)
  finalReportDate         DateTime?
  finalReportPath         String?
  overallOutcome          String?         @db.Text
  recommendationsForFuture String?        @db.Text
  satisfactionRating      NGOSatisfactionRating?
  
  // Metadata
  notes                   String?         @db.Text
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  
  @@index([caseId])
  @@index([partnershipNumber])
}

// ============================================
// CHAT MESSAGES - Team Communication (PHASE 3)
// ============================================

enum MessageType {
  TEXT
  FILE
  IMAGE
  VIDEO
  AUDIO
  SYSTEM
  NOTIFICATION
}

enum ReactionType {
  LIKE
  LOVE
  HELPFUL
  NOTED
}

model ChatMessage {
  id                      String          @id @default(cuid())
  caseId                  String
  case                    Case            @relation(fields: [caseId], references: [id], onDelete: Cascade)
  messageNumber           Int
  
  // Sender Information
  senderId                String
  senderName              String
  senderRole              String?
  
  // Message Content
  messageText             String          @db.Text
  messageType             MessageType     @default(TEXT)
  isSystemMessage         Boolean         @default(false)
  isImportant             Boolean         @default(false)
  isPinned                Boolean         @default(false)
  
  // File Attachments
  attachments             Json[]          // Array of attachment objects
  
  // Interaction
  readBy                  String[]
  readReceipts            Json[]          // Array of read receipt objects
  reactions               Json[]          // Array of reaction objects
  
  // Threading
  replyToMessageId        String?
  threadId                String?
  isThreadStarter         Boolean         @default(false)
  threadRepliesCount      Int             @default(0)
  
  // Pinned Messages
  pinnedBy                String?
  pinnedByName            String?
  pinnedAt                DateTime?
  pinnedReason            String?         @db.Text
  
  // Metadata
  editedAt                DateTime?
  editedBy                String?
  deletedAt               DateTime?
  deletedBy               String?
  isDeleted               Boolean         @default(false)
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  
  @@index([caseId])
  @@index([senderId])
  @@index([messageNumber])
  @@index([isPinned])
  @@index([isDeleted])
}

// ============================================
// SEARCH MANAGEMENT
// ============================================

model SearchHistory {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation("UserSearchHistory", fields: [userId], references: [id], onDelete: Cascade)
  searchQuery String
  searchType  String   @default("all")
  filters     Json?
  resultCount Int      @default(0)
  createdAt   DateTime @default(now())
  
  @@index([userId])
  @@index([createdAt])
}

model SavedSearch {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation("UserSavedSearches", fields: [userId], references: [id], onDelete: Cascade)
  name        String
  searchQuery String
  searchType  String   @default("all")
  filters     Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([userId])
  @@index([createdAt])
}

// ============================================
// CONTENT MANAGEMENT SYSTEM (CMS)
// ============================================

enum NewsStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model NewsArticle {
  id          String      @id @default(cuid())
  title       String      @db.Text
  excerpt     String?     @db.Text
  content     String      @db.Text
  category    String      @default("General")
  status      NewsStatus  @default(DRAFT)
  featured    Boolean     @default(false)
  imageUrl    String?
  imageAlt    String?
  authorId    String
  author      User        @relation("NewsAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  authorName  String
  publishedAt DateTime?
  views       Int         @default(0)
  tags        String[]
  metadata    Json?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  @@index([status])
  @@index([category])
  @@index([publishedAt])
  @@index([featured])
  @@index([authorId])
}

model PageContent {
  id          String   @id @default(cuid())
  pageSlug    String   @unique
  title       String
  content     String   @db.Text
  excerpt     String?  @db.Text
  metadata    Json?
  updatedById String
  updatedBy   User     @relation("PageContentEditor", fields: [updatedById], references: [id], onDelete: Cascade)
  updatedByName String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([pageSlug])
}

