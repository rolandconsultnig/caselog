model suspects {
  id                                                             Int                         @id @default(autoincrement())
  investigation_id                                               Int
  alias                                                          String                      @db.VarChar(255)
  real_name                                                      String?                     @db.VarChar(255)
  known_aliases                                                  Json?                       @db.Json
  bio                                                            String?
  profile_image_url                                              String?                     @db.VarChar(1000)
  social_accounts                                                Json?                       @db.Json
  threat_score                                                   Float?
  risk_level                                                     threatlevel
  post_count                                                     Int?
  total_engagement                                               Int?
  network_size                                                   Int?
  activity_pattern                                               Json?                       @db.Json
  communication_style                                            String?
  known_associates                                               Json?                       @db.Json
  known_locations                                                Json?                       @db.Json
  primary_location                                               String?                     @db.VarChar(255)
  ip_addresses                                                   Json?                       @db.Json
  is_active                                                      Boolean?
  is_confirmed                                                   Boolean?
  notes                                                          String?
  tags                                                           Json?                       @db.Json
  first_detected_at                                              DateTime                    @db.Timestamptz(6)
  last_activity_at                                               DateTime                    @db.Timestamptz(6)
  created_at                                                     DateTime?                   @default(now()) @db.Timestamptz(6)
  updated_at                                                     DateTime?                   @db.Timestamptz(6)
  conversation_participants                                      conversation_participants[]
  evidence                                                       evidence[]
  network_connections_network_connections_suspect_id_1Tosuspects network_connections[]       @relation("network_connections_suspect_id_1Tosuspects")
  network_connections_network_connections_suspect_id_2Tosuspects network_connections[]       @relation("network_connections_suspect_id_2Tosuspects")
  investigations                                                 investigations              @relation(fields: [investigation_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([alias], map: "ix_suspects_alias")
  @@index([first_detected_at], map: "ix_suspects_first_detected_at")
  @@index([id], map: "ix_suspects_id")
  @@index([investigation_id], map: "ix_suspects_investigation_id")
  @@index([is_active], map: "ix_suspects_is_active")
  @@index([last_activity_at], map: "ix_suspects_last_activity_at")
  @@index([primary_location], map: "ix_suspects_primary_location")
  @@index([risk_level], map: "ix_suspects_risk_level")
  @@index([threat_score], map: "ix_suspects_threat_score")
}

model threat_alerts {
  id                                            Int             @id @default(autoincrement())
  investigation_id                              Int?
  alert_type                                    String          @db.VarChar(100)
  severity                                      threatlevel
  title                                         String          @db.VarChar(500)
  description                                   String?
  source_type                                   String?         @db.VarChar(50)
  source_id                                     Int?
  triggered_by                                  Json?           @db.Json
  context_data                                  Json?           @db.Json
  is_acknowledged                               Boolean?
  acknowledged_by_id                            Int?
  acknowledged_at                               DateTime?       @db.Timestamptz(6)
  is_resolved                                   Boolean?
  resolved_by_id                                Int?
  resolved_at                                   DateTime?       @db.Timestamptz(6)
  resolution_notes                              String?
  triggered_at                                  DateTime        @db.Timestamptz(6)
  created_at                                    DateTime?       @default(now()) @db.Timestamptz(6)
  users_threat_alerts_acknowledged_by_idTousers users?          @relation("threat_alerts_acknowledged_by_idTousers", fields: [acknowledged_by_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  investigations                                investigations? @relation(fields: [investigation_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_threat_alerts_resolved_by_idTousers     users?          @relation("threat_alerts_resolved_by_idTousers", fields: [resolved_by_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([alert_type], map: "ix_threat_alerts_alert_type")
  @@index([id], map: "ix_threat_alerts_id")
  @@index([investigation_id], map: "ix_threat_alerts_investigation_id")
  @@index([is_acknowledged], map: "ix_threat_alerts_is_acknowledged")
  @@index([is_resolved], map: "ix_threat_alerts_is_resolved")
  @@index([severity], map: "ix_threat_alerts_severity")
  @@index([triggered_at], map: "ix_threat_alerts_triggered_at")
}

model users {
  id                                                    Int                      @id @default(autoincrement())
  email                                                 String                   @unique(map: "ix_users_email") @db.VarChar(255)
  username                                              String                   @unique(map: "ix_users_username") @db.VarChar(100)
  hashed_password                                       String?                  @db.VarChar(255)
  is_active                                             Boolean?
  role                                                  userrole
  full_name                                             String?                  @db.VarChar(255)
  created_at                                            DateTime?                @default(now()) @db.Timestamptz(6)
  updated_at                                            DateTime?                @db.Timestamptz(6)
  last_login                                            DateTime?                @db.Timestamptz(6)
  custody_chain                                         custody_chain[]
  evidence_evidence_collected_by_idTousers              evidence[]               @relation("evidence_collected_by_idTousers")
  evidence_evidence_verified_by_idTousers               evidence[]               @relation("evidence_verified_by_idTousers")
  investigation_timeline                                investigation_timeline[]
  investigations                                        investigations[]
  threat_alerts_threat_alerts_acknowledged_by_idTousers threat_alerts[]          @relation("threat_alerts_acknowledged_by_idTousers")
  threat_alerts_threat_alerts_resolved_by_idTousers     threat_alerts[]          @relation("threat_alerts_resolved_by_idTousers")
  watchlists                                            watchlists[]

  @@index([id], map: "ix_users_id")
}

model watchlist_keywords {
  id                    Int        @id @default(autoincrement())
  watchlist_id          Int
  keyword               String     @db.VarChar(255)
  use_semantic_matching Boolean?
  use_fuzzy_matching    Boolean?
  created_at            DateTime?  @default(now()) @db.Timestamptz(6)
  watchlists            watchlists @relation(fields: [watchlist_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([id], map: "ix_watchlist_keywords_id")
  @@index([keyword], map: "ix_watchlist_keywords_keyword")
}

model watchlists {
  id                 Int                  @id @default(autoincrement())
  name               String               @db.VarChar(255)
  description        String?
  user_id            Int?
  is_active          Boolean?
  created_at         DateTime?            @default(now()) @db.Timestamptz(6)
  updated_at         DateTime?            @db.Timestamptz(6)
  posts              posts[]
  watchlist_keywords watchlist_keywords[]
  users              users?               @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([id], map: "ix_watchlists_id")
}

