generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String     @id @default(cuid())
  name      String     @unique
  code      String     @unique
  type      TenantType
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  cases     Case[]
  users     User[]

  @@index([type])
  @@index([code])
}

model User {
  id                 String          @id @default(cuid())
  username           String          @unique
  email              String?
  password           String
  firstName          String
  lastName           String
  phoneNumber        String?
  accessLevel        AccessLevel
  tenantId           String
  isActive           Boolean         @default(true)
  lastLogin          DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  auditLogs          AuditLog[]
  casesCoordinating  Case[]          @relation("CaseCoordinator")
  casesCreated       Case[]          @relation("CaseCreator")
  casesInvestigating Case[]          @relation("CaseInvestigator")
  casesApproved      Case[]          @relation("CaseApprover")
  casesProsecuting   Case[]          @relation("CaseProsecutor")
  casesModificationApproved Case[]    @relation("CaseModificationApprover")
  newsArticles       NewsArticle[]   @relation("NewsAuthor")
  pageContent        PageContent[]   @relation("PageContentEditor")
  savedSearches      SavedSearch[]   @relation("UserSavedSearches")
  searchHistory      SearchHistory[] @relation("UserSearchHistory")
  tenant             Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([accessLevel])
  @@index([username])
}

model Case {
  id                         String             @id @default(cuid())
  caseNumber                 String             @unique
  mojCaseNumber              String?            @unique
  reportedDate               DateTime           @default(now())
  title                      String
  description                String
  incidentDate               DateTime
  incidentState              String
  caseType                   CaseType           @default(SGBV)
  status                     CaseStatus         @default(NEW)
  priority                   CasePriority       @default(MEDIUM)
  incidentLga                String?
  incidentAddress            String?
  incidentLocation           Json?
  reportedState              String?
  reportedLga                String?
  reportedAddress            String?
  investigatorId             String?
  coordinatorId              String?
  assignedState              String?
  jurisdiction               Jurisdiction       @default(FEDERAL)
  initialAssessmentCompleted Boolean            @default(false)
  investigationStarted       Boolean            @default(false)
  courtDate                  DateTime?
  courtStatus                String?
  finalOutcome               String?
  convictionDate             DateTime?
  sentence                   String?
  isSensitive                Boolean            @default(false)
  requiresSpecialHandling    Boolean            @default(false)
  mediaInvolved              Boolean            @default(false)
  international              Boolean            @default(false)
  crossJurisdictional        Boolean            @default(false)
  
  // Approval workflow fields
  approvedBy                 String?            // Level 3 who approved
  approvedAt                 DateTime?          // When approved
  prosecutorId               String?            // Assigned prosecutor
  prosecutorAssignedAt       DateTime?          // When prosecutor was assigned
  modificationApprovedBy     String?            // Level 4 who approved modification
  modificationApprovedAt     DateTime?          // When modification was approved
  
  tenantId                   String
  createdById                String
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt
  auditLogs                  AuditLog[]
  coordinator                User?              @relation("CaseCoordinator", fields: [coordinatorId], references: [id])
  createdBy                  User               @relation("CaseCreator", fields: [createdById], references: [id])
  investigator               User?              @relation("CaseInvestigator", fields: [investigatorId], references: [id])
  approver                   User?              @relation("CaseApprover", fields: [approvedBy], references: [id])
  prosecutor                 User?              @relation("CaseProsecutor", fields: [prosecutorId], references: [id])
  modificationApprover       User?              @relation("CaseModificationApprover", fields: [modificationApprovedBy], references: [id])
  tenant                     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  civilSocieties             CaseCivilSociety[]
  files                      CaseFile[]
  services                   CaseService[]
  chatMessages               ChatMessage[]
  courtRecords               CourtRecord[]
  evidence                   Evidence[]
  perpetrators               Perpetrator[]
  victims                    Victim[]
  witnesses                  Witness[]

  @@index([tenantId])
  @@index([status])
  @@index([caseNumber])
  @@index([createdById])
  @@index([caseType])
  @@index([priority])
  @@index([incidentDate])
  @@index([investigatorId])
  @@index([coordinatorId])
}

