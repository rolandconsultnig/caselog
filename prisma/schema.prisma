// Internal Email System
model InternalEmail {
  id              String          @id @default(cuid())
  subject         String
  body            String          @db.Text
  senderId        String
  senderName      String
  senderEmail     String?
  recipientIds    String[]
  recipientEmails String[]        // For external email addresses
  ccIds           String[]
  bccIds          String[]
  attachments     Json[]
  isRead          Boolean         @default(false)
  isStarred       Boolean         @default(false)
  isArchived      Boolean         @default(false)
  isDraft         Boolean         @default(false)
  isDeleted       Boolean         @default(false)
  deletedBy       String[]
  readBy          String[]
  readAt          DateTime?
  priority        EmailPriority   @default(NORMAL)
  category        EmailCategory   @default(GENERAL)
  caseId          String?
  replyToId       String?
  threadId        String?
  sentAt          DateTime        @default(now())
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([senderId])
  @@index([caseId])
  @@index([threadId])
  @@index([sentAt])
  @@index([isDeleted])
}

enum EmailPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum EmailCategory {
  GENERAL
  CASE_RELATED
  ADMINISTRATIVE
  URGENT
  ANNOUNCEMENT
}
